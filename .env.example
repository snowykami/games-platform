PORT=8901
APP_ENV=development
SESSION_COOKIE_SECURE=false

# Local services. Real deployments should inject these as environment variables.
DB_URL=postgres://games_platform:games_platform@localhost:5436/games_platform?sslmode=disable
REDIS_URL=redis://localhost:6385/0

# Global LLM provider for all future AI players.
# Keep real tokens in local .env files or deployment secrets.
LLM_API=
LLM_MODEL=
LLM_TOKEN=

# JSON array. Each item defines one OIDC provider.
# Example:
# OIDC_PROVIDERS_JSON='[{"key":"google","displayName":"Google","issuerUrl":"https://accounts.google.com","clientId":"xxx","clientSecret":"xxx","redirectUrl":"http://localhost:5173/api/auth/oidc/google/callback"}]'
OIDC_PROVIDERS_JSON=
